# Copy to .env and adjust. All settings are optional; sensible defaults apply.

# Where the SQLite DB and uploads live
RAP_DATA_DIR=./backend/data

# Embeddings (falls back to deterministic TF-IDF when Ollama is unreachable)
RAP_OLLAMA_BASE_URL=http://127.0.0.1:11434
RAP_OLLAMA_MODEL=nomic-embed-text

# Screening
RAP_DEFAULT_SHORTLIST_THRESHOLD=70.0

# HTTP
RAP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
RAP_MAX_UPLOAD_BYTES=5242880
RAP_ENABLE_METRICS=true

# Logging
RAP_LOG_LEVEL=INFO
